      "link": null,
      "locked": false,
      "text": "Generate Router (SSE)\nGET /api/sessions/{id}/generate\nPhase 1: summarise_file() — concurrency=5\nPhase 2: answer_with_citations() per DD Q — concurrency=5\nStreams: file_start/done, question_start/done events",
      "rawText": "Generate Router (SSE)\nGET /api/sessions/{id}/generate\nPhase 1: summarise_file() — concurrency=5\nPhase 2: answer_with_citations() per DD Q — concurrency=5\nStreams: file_start/done, question_start/done events",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Generate Router (SSE)\nGET /api/sessions/{id}/generate\nPhase 1: summarise_file() — concurrency=5\nPhase 2: answer_with_citations() per DD Q — concurrency=5\nStreams: file_start/done, question_start/done events",
      "lineHeight": 1.25
    },
