      "text": "Sessions Router\nPOST   /api/sessions          — create + upload files\nGET    /api/sessions           — list sessions\nGET    /api/sessions/{id}      — session detail\nDELETE /api/sessions/{id}      — soft-delete",
      "rawText": "Sessions Router\nPOST   /api/sessions          — create + upload files\nGET    /api/sessions           — list sessions\nGET    /api/sessions/{id}      — session detail\nDELETE /api/sessions/{id}      — soft-delete",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sessions Router\nPOST   /api/sessions          — create + upload files\nGET    /api/sessions           — list sessions\nGET    /api/sessions/{id}      — session detail\nDELETE /api/sessions/{id}      — soft-delete",
      "lineHeight": 1.25
    },
