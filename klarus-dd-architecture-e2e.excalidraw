    {
      "id": "frontend-content",
      "type": "text",
      "x": 215,
      "y": 158,
      "width": 295,
      "height": 430,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "text": "Pages\n• Home — session list\n• /session/[id] — workspace\n\nComponents\n• IntakeForm\n  upload files, config session\n• SessionView\n  full workspace layout\n• ChatPanel\n  SSE streaming chat\n• DataRoomSidebar\n  file summaries + tags\n• QASidebar\n  10 DD Q&A answers\n• CitationDrawer\n  PDF viewer + page jump",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pages\n• Home — session list\n• /session/[id] — workspace\n\nComponents\n• IntakeForm\n  upload files, config session\n• SessionView\n  full workspace layout\n• ChatPanel\n  SSE streaming chat\n• DataRoomSidebar\n  file summaries + tags\n• QASidebar\n  10 DD Q&A answers\n• CitationDrawer\n  PDF viewer + page jump",
      "lineHeight": 1.25
    },
