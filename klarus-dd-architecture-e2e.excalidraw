    {
      "id": "backend-content",
      "type": "text",
      "x": 592,
      "y": 158,
      "width": 315,
      "height": 370,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "text": "API Routes\n• POST /api/sessions\n• GET  /api/sessions\n• GET  /api/sessions/{id}\n• GET  /api/sessions/{id}/generate → SSE\n  file summaries + DD Q&A generation\n• POST /api/sessions/{id}/chat → SSE\n  agentic chat loop w/ tool calls\n• GET  /api/files/{id}/raw\n• DELETE /api/sessions/{id}\n\nModules\n• gemini_provider — LLM + streaming\n• citations — [file p.X] regex parser\n• file_processing — upload + validation\n• dd_questions — 10-Q DD template",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API Routes\n• POST /api/sessions\n• GET  /api/sessions\n• GET  /api/sessions/{id}\n• GET  /api/sessions/{id}/generate → SSE\n  file summaries + DD Q&A generation\n• POST /api/sessions/{id}/chat → SSE\n  agentic chat loop w/ tool calls\n• GET  /api/files/{id}/raw\n• DELETE /api/sessions/{id}\n\nModules\n• gemini_provider — LLM + streaming\n• citations — [file p.X] regex parser\n• file_processing — upload + validation\n• dd_questions — 10-Q DD template",
      "lineHeight": 1.25
    },
